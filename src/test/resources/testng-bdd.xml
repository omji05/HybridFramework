<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="BDD Only Suite"
       parallel="methods"
       thread-count="${parallel.thread.count}"
       verbose="2">

    <listeners>
        <listener class-name="com.hybrid.framework.listeners.TestNGListener"/>
    </listeners>

    <!-- ════════════════════════════════════════════════════ -->
    <!--  Primary BDD execution                             -->
    <!--  Tags controlled via: -Dbdd.tags="@tagName"        -->
    <!-- ════════════════════════════════════════════════════ -->
    <test name="BDD Tests">
        <classes>
            <class name="com.hybrid.framework.runners.TestRunner"/>
        </classes>
    </test>

    <!-- Re-run failed scenarios from target/rerun.txt -->
    <test name="BDD Failed Scenarios Retry">
        <classes>
            <class name="com.hybrid.framework.runners.FailedScenariosRunner"/>
        </classes>
    </test>

</suite>

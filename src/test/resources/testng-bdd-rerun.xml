<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="BDD Rerun Suite"
       parallel="methods"
       thread-count="${parallel.thread.count}"
       verbose="2">

    <listeners>
        <listener class-name="com.hybrid.framework.listeners.TestNGListener"/>
    </listeners>

    <!-- Re-run failed scenarios from target/rerun.txt (CI job 2). -->
    <test name="BDD Failed Scenarios Retry">
        <classes>
            <class name="com.hybrid.framework.runners.FailedScenariosRunner"/>
        </classes>
    </test>

</suite>

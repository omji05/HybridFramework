<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="BDD Primary Suite"
       parallel="methods"
       thread-count="${parallel.thread.count}"
       verbose="2">

    <listeners>
        <listener class-name="com.hybrid.framework.listeners.TestNGListener"/>
    </listeners>

    <!-- Primary BDD execution only (CI job 1). Writes target/rerun.txt on failures. -->
    <test name="BDD Tests">
        <classes>
            <class name="com.hybrid.framework.runners.TestRunner"/>
        </classes>
    </test>

</suite>

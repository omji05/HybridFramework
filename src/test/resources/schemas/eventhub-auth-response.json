{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventHub Auth Response",
  "type": "object",
  "required": ["success", "token", "user"],
  "properties": {
    "success": { "type": "boolean" },
    "token": { "type": "string", "minLength": 1 },
    "user": {
      "type": "object",
      "required": ["id", "email"],
      "properties": {
        "id": { "type": "integer" },
        "email": { "type": "string", "format": "email" }
      }
    }
  }
}

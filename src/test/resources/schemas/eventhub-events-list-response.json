{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventHub Events List Response",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": { "type": "boolean" },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" }
        }
      }
    },
    "pagination": { "type": "object" }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RealWorld Error Response",
  "type": "object",
  "required": ["errors"],
  "additionalProperties": false,
  "properties": {
    "errors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 1
      }
    }
  }
}

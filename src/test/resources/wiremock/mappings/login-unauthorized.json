{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/api/users/login",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.user.email",
        "equalTo": "bad@example.com"
      }
    ]
  },
  "response": {
    "status": 401,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "login-unauthorized.json"
  }
}

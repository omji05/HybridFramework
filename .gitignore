# ═══════════════════════════════════════════════════════════════
#                      .gitignore
# ═══════════════════════════════════════════════════════════════

# ──────────── Build output ────────────
target/
build/
out/
*.class

# ──────────── IDE ────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/
*.swp
*.swo
*~

# ──────────── Maven ────────────
dependency-reduced-pom.xml
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# ──────────── Reports (generated) ────────────
logs/

# ──────────── OS ────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────── Secrets (NEVER commit) ────────────
*.env
.env.*
credentials.json
secrets.properties

# ──────────── Local tooling ────────────
.allure/
.venv-pdf/
test-output/
.cursor/
docs/